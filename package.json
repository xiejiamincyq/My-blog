{
  "name": "xiami-blog",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/astro.mjs dev",
    "build": "node scripts/build.mjs",
    "preview": "node scripts/astro.mjs preview",
    "format": "prettier --write \"src/**/*.{astro,ts,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,md,css}\"",
    "typecheck": "node scripts/astro.mjs check",
    "typecheck:strict": "node scripts/astro.mjs check --minimumFailingSeverity warning",
    "check:comment-ui": "node scripts/check-comment-ui.mjs",
    "check:homepage-ui": "node scripts/check-homepage-ui.mjs",
    "lint:md": "markdownlint \"src/content/**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"src/content/**/*.md\""
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "markdownlint-cli": "^0.49.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "supabase": "^2.109.0"
  }
}
