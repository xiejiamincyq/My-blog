---
import BaseLayout from "./BaseLayout.astro";
import GiscusComments from "../components/GiscusComments.astro";
import TagList from "../components/TagList.astro";
import { sitePath } from "../lib/paths";
import { SEO_DEFAULTS, absoluteURL } from "../lib/seo";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: ImageMetadata;
  ogImage?: ImageMetadata;
}

const { title, description, pubDate, updatedDate, tags, heroImage, ogImage } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);

const site = Astro.site ?? new URL(SEO_DEFAULTS.siteUrl);
const structuredImage = ogImage ?? heroImage;
const structuredImageUrl = structuredImage
  ? absoluteURL(sitePath(structuredImage.src), site)
  : undefined;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: SEO_DEFAULTS.authorName,
  },
  publisher: {
    "@type": "Person",
    name: SEO_DEFAULTS.authorName,
  },
  mainEntityOfPage: absoluteURL(Astro.url.pathname, site),
  keywords: tags.join(", "),
  ...(structuredImageUrl && { image: structuredImageUrl }),
  inLanguage: "zh-CN",
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={structuredImageUrl}
  ogType="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
>
  <article class="post-shell">
    <a class="back-link" href={sitePath("/blog/")}>返回文章</a>
    <header class="post-header">
      <p class="eyebrow">{formatDate(pubDate)}</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {updatedDate && <p class="updated">更新于 {formatDate(updatedDate)}</p>}
      <TagList tags={tags} />
    </header>
    {
      heroImage && (
        <figure class="post-hero-image">
          <Image
            src={heroImage}
            alt={title}
            widths={[720, 1200]}
            sizes="(max-width: 760px) 100vw, 720px"
            loading="eager"
            decoding="async"
          />
        </figure>
      )
    }
    <div class="prose">
      <slot />
    </div>
    <GiscusComments />
  </article>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
</BaseLayout>
