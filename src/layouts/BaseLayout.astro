---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { sitePath } from "../lib/paths";
import { SEO_DEFAULTS, absoluteURL, canonicalURL, formatPageTitle } from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const site = Astro.site ?? new URL(SEO_DEFAULTS.siteUrl);
const {
  title = SEO_DEFAULTS.title,
  description = SEO_DEFAULTS.description,
  ogImage = SEO_DEFAULTS.ogImage,
  ogType = "website",
  pubDate,
  updatedDate,
  tags = [],
} = Astro.props;

const pageTitle = formatPageTitle(title);
const canonical = canonicalURL(Astro.url.pathname, site);
const ogImageUrl = absoluteURL(ogImage, site);
const rssUrl = absoluteURL(sitePath("rss.xml"), site);
const backgroundImage = `url("${sitePath("images/cyberpunk-skyline-4k.png")}")`;
const lightBackgroundImage = `url("${sitePath("images/sunny-anime-light-bg-4k.png")}")`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const theme = stored === "light" ? "light" : "dark";
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = "dark";
          document.documentElement.style.colorScheme = "dark";
        }
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SEO_DEFAULTS.siteName} RSS`}
      href={rssUrl}
    />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SEO_DEFAULTS.siteName} />
    <meta property="og:locale" content={SEO_DEFAULTS.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <title>{pageTitle}</title>
  </head>
  <body
    style={`--background-image: ${backgroundImage}; --light-background-image: ${lightBackgroundImage};`}
  >
    <div class="site-backdrop" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
