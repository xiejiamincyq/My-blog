---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllTags, getPublishedPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const tags = await getAllTags();

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) =>
  post.data.tags.includes(tag),
);
---

<BaseLayout title={`标签：${tag}`} description={`查看标签 ${tag} 下的文章。`}>
  <section class="page-header">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <p>共有 {posts.length} 篇文章。</p>
  </section>

  <section class="post-list" aria-label={`标签 ${tag} 下的文章`}>
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
