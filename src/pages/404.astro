---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePath } from "../lib/paths";
---

<BaseLayout title="页面未找到" description="这个页面不存在。">
  <section class="page-header not-found">
    <p class="eyebrow">404</p>
    <h1>这个页面暂时不存在</h1>
    <p>也许文章被移动了，或者链接里有一个小小的笔误。</p>
    <a class="button primary" href={sitePath("/")}>回到首页</a>
  </section>
</BaseLayout>
