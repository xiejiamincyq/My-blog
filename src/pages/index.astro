---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Search from "../components/Search.astro";
import { getPublishedPosts } from "../lib/posts";
import { sitePath } from "../lib/paths";

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 2);
const latestPosts = posts.slice(0, 4);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">个人博客</p>
      <h1>把日常里的想法，<br />慢慢写成自己的地图。</h1>
      <p>
        这里记录技术、阅读、生活观察和一些仍在路上的问题。文章不追求热闹， 更像一张持续生长的书桌。
      </p>
      <div class="hero-actions">
        <a class="button primary" href={sitePath("/blog/")}>阅读文章</a>
        <a class="button secondary" href={sitePath("/about/")}>了解我</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="博客状态">
      <span>正在写</span>
      <strong>{posts.length}</strong>
      <p>篇文章</p>
    </div>
  </section>

  <section class="hero-search-section" aria-label="站内搜索">
    <Search />
  </section>

  {
    featuredPosts.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <p class="eyebrow">精选</p>
          <h2>先从这些开始</h2>
        </div>
        <div class="post-grid">
          {featuredPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="section-heading row">
      <div>
        <p class="eyebrow">最新</p>
        <h2>最近写下的内容</h2>
      </div>
      <a class="text-link" href={sitePath("/blog/")}>全部文章</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
