---
import { sitePath } from "../lib/paths";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="tag-list" aria-label="文章标签">
      {tags.map((tag) => (
        <li>
          <a href={sitePath(`/tags/${encodeURIComponent(tag)}/`)}>{tag}</a>
        </li>
      ))}
    </ul>
  )
}
