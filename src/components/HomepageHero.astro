---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { sitePath } from "../lib/paths";

interface Props {
  heroImage?: ImageMetadata;
  lightHeroImage?: ImageMetadata;
}

const { heroImage, lightHeroImage } = Astro.props;
---

<section class="home-hero" aria-labelledby="home-title">
  <div class="home-hero-copy" data-home-reveal>
    <p class="home-eyebrow">个人博客</p>
    <h1 id="home-title">给思考留一块<br />会呼吸的地方</h1>
    <p class="home-hero-lede">记录技术、阅读、生活观察，以及仍在生长的问题。</p>
    <div class="hero-actions">
      <a class="button primary" href={sitePath("/blog/")}>阅读文章</a>
      <a class="button secondary" href={sitePath("/about/")}>了解我</a>
    </div>
  </div>

  <div class="home-hero-visual" data-home-reveal>
    <div class="home-hero-media">
      {
        heroImage ? (
          <div
            class="home-hero-artwork"
            role="img"
            aria-label="由透明花朵、幼苗与流动玻璃构成的数字花园"
          >
            <Image
              class="home-hero-image home-hero-image--dark"
              src={heroImage}
              alt=""
              widths={[640, 960]}
              sizes="(max-width: 760px) 100vw, 48vw"
              loading="eager"
              decoding="async"
            />
            {lightHeroImage && (
              <Image
                class="home-hero-image home-hero-image--light"
                src={lightHeroImage}
                alt=""
                widths={[640, 960]}
                sizes="(max-width: 760px) 100vw, 48vw"
                loading="eager"
                decoding="async"
              />
            )}
          </div>
        ) : (
          <div class="home-hero-media-fallback" aria-hidden="true" />
        )
      }
    </div>
  </div>
</section>
