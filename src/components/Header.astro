---
const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "文章" },
  { href: "/tags/", label: "标签" },
  { href: "/about/", label: "关于" },
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label="回到首页">
    <span class="brand-mark">虾</span>
    <span>虾米的博客</span>
  </a>
  <nav aria-label="主导航">
    {
      navItems.map((item) => (
        <a href={item.href} aria-current={Astro.url.pathname === item.href ? "page" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
