---
import ThemeToggle from "./ThemeToggle.astro";
import AuthStatus from "./AuthStatus.astro";
import { sitePath } from "../lib/paths";

const navItems = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "文章" },
  { href: "/tags/", label: "标签" },
  { href: "/about/", label: "关于" },
];
---

<header class="site-header">
  <a class="brand" href={sitePath("/")} aria-label="回到首页">
    <span class="brand-mark">虾</span>
    <span>虾米的博客</span>
  </a>
  <div class="header-end">
    <nav aria-label="主导航">
      {
        navItems.map((item) => (
          <a
            href={sitePath(item.href)}
            aria-current={Astro.url.pathname === sitePath(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <AuthStatus />
    <ThemeToggle />
  </div>
</header>
