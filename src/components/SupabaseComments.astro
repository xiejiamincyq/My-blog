---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section class="comments-panel" data-comments data-post-slug={postSlug}>
  <div class="comments-heading">
    <div>
      <p class="eyebrow">Comments</p>
      <h2>评论</h2>
    </div>
    <button class="auth-button" type="button" data-comments-login>登录后评论</button>
  </div>

  <form class="comment-form" data-comment-form hidden>
    <label for="comment-content">写下你的想法</label>
    <textarea id="comment-content" name="content" rows="4" maxlength="2000" required></textarea>
    <div class="comment-form-actions">
      <span data-comment-status></span>
      <button class="button primary" type="submit">发布评论</button>
    </div>
  </form>

  <div class="comment-list" data-comment-list></div>
  <p class="comments-empty" data-comments-empty hidden>还没有评论，来写第一条吧。</p>
  <p class="comments-empty" data-comments-unavailable hidden>
    评论系统尚未配置。阅读不受影响，配置 Supabase 后即可发表评论。
  </p>
</section>

<style>
  .comments-panel {
    margin-top: 56px;
    border-top: 1px solid var(--line);
    padding-top: 40px;
  }

  .comments-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 20px;
  }

  .comments-heading h2 {
    font-size: 28px;
  }

  .comment-form {
    display: grid;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 18px;
  }

  .comment-form[hidden] {
    display: none;
  }

  .comment-form label {
    font-weight: 800;
  }

  .comment-form textarea {
    width: 100%;
    resize: vertical;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.76);
    color: var(--text);
    font: inherit;
    padding: 12px;
  }

  .comment-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
  }

  .comment-list {
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .comment-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 16px;
  }

  .comment-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 14px;
  }

  .comment-meta img {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    object-fit: cover;
  }

  .comment-body {
    white-space: pre-wrap;
  }

  .comments-empty {
    color: var(--muted);
  }
</style>

<script>
  // @ts-nocheck
  import { getSupabaseClient, getUserLabel } from "../lib/supabase-browser";

  const root = document.querySelector("[data-comments]");
  const supabase = await getSupabaseClient();
  const postSlug = root?.dataset.postSlug;
  const list = root?.querySelector("[data-comment-list]");
  const empty = root?.querySelector("[data-comments-empty]");
  const unavailable = root?.querySelector("[data-comments-unavailable]");
  const loginButton = root?.querySelector("[data-comments-login]");
  const form = root?.querySelector("[data-comment-form]");
  const textarea = form?.querySelector("textarea");
  const status = root?.querySelector("[data-comment-status]");

  const escapeHTML = (value) =>
    value.replace(/[&<>"']/g, (char) => {
      const map = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" };
      return map[char];
    });

  const formatDate = (value) =>
    new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(value));

  const renderAuth = async () => {
    if (!supabase) return;
    const { data } = await supabase.auth.getUser();
    const user = data.user;
    loginButton.hidden = Boolean(user);
    form.hidden = !user;
  };

  const loadComments = async () => {
    if (!root || !postSlug || !list) return;

    if (!supabase) {
      unavailable.hidden = false;
      loginButton.hidden = true;
      return;
    }

    const { data, error } = await supabase
      .from("comments")
      .select("id, author_name, author_avatar, content, created_at")
      .eq("post_slug", postSlug)
      .eq("status", "visible")
      .order("created_at", { ascending: true });

    if (error) {
      unavailable.hidden = false;
      return;
    }

    list.innerHTML = (data ?? [])
      .map(
        (comment) => `
          <article class="comment-card">
            <div class="comment-meta">
              ${comment.author_avatar ? `<img src="${comment.author_avatar}" alt="" />` : ""}
              <strong>${escapeHTML(comment.author_name)}</strong>
              <span>${formatDate(comment.created_at)}</span>
            </div>
            <div class="comment-body">${escapeHTML(comment.content)}</div>
          </article>
        `,
      )
      .join("");

    empty.hidden = Boolean(data?.length);
  };

  loginButton?.addEventListener("click", async () => {
    await supabase?.auth.signInWithOAuth({
      provider: "github",
      options: { redirectTo: window.location.href },
    });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    status.textContent = "发布中...";

    const { data } = await supabase.auth.getUser();
    const user = data.user;
    if (!user) {
      status.textContent = "请先登录。";
      return;
    }

    const content = textarea.value.trim();
    if (!content) {
      status.textContent = "评论不能为空。";
      return;
    }

    const { error } = await supabase.from("comments").insert({
      post_slug: postSlug,
      user_id: user.id,
      author_name: getUserLabel(user),
      author_avatar: user.user_metadata?.avatar_url,
      content,
    });

    if (error) {
      status.textContent = "发布失败，请稍后重试。";
      return;
    }

    textarea.value = "";
    status.textContent = "已发布。";
    await loadComments();
  });

  window.addEventListener("blog-auth-change", renderAuth);
  await renderAuth();
  await loadComments();
</script>
