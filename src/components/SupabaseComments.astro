---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section class="comments-panel" data-comments data-post-slug={postSlug}>
  <div class="comments-heading">
    <div>
      <p class="eyebrow">Comments</p>
      <h2>评论 <span data-comment-count>0</span></h2>
    </div>
    <button class="auth-button" type="button" data-comments-login>登录后评论</button>
  </div>

  <form class="comment-form" data-comment-form hidden>
    <label for="comment-content">写下你的想法</label>
    <textarea
      id="comment-content"
      name="content"
      rows="4"
      maxlength="2000"
      placeholder="自由写，直接发。"
      required></textarea>
    <div class="comment-form-actions">
      <span data-comment-status aria-live="polite"></span>
      <button class="button primary" type="submit" data-comment-submit>发布评论</button>
    </div>
  </form>

  <p class="comments-empty" data-comments-loading>正在加载评论...</p>
  <div class="comment-list" data-comment-list aria-live="polite"></div>
  <p class="comments-empty" data-comments-empty hidden>还没有评论，来写第一条吧。</p>
  <p class="comments-empty" data-comments-unavailable hidden>
    评论系统尚未配置。阅读不受影响，配置 Supabase 后即可发表评论。
  </p>
</section>

<style>
  .comments-panel {
    margin-top: 56px;
    border-top: 1px solid var(--line);
    padding-top: 40px;
  }

  .comments-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 20px;
  }

  .comments-heading h2 {
    margin: 0;
    font-size: 28px;
  }

  .comments-heading h2 span {
    color: var(--muted);
    font-size: 18px;
  }

  .comment-form {
    display: grid;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: linear-gradient(180deg, var(--surface-strong), var(--surface));
    padding: 18px;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  .comment-form[hidden] {
    display: none;
  }

  .comment-form label {
    font-weight: 800;
  }

  .comment-form textarea {
    width: 100%;
    min-height: 112px;
    resize: vertical;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(5, 9, 18, 0.52);
    color: var(--text);
    font: inherit;
    line-height: 1.7;
    padding: 12px;
  }

  .comment-form textarea:focus {
    border-color: rgba(71, 233, 255, 0.45);
    outline: none;
  }

  .comment-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    min-height: 44px;
  }

  .comment-list {
    display: grid;
    gap: 12px;
    margin-top: 20px;
  }

  .comment-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(8, 13, 24, 0.74), rgba(8, 13, 24, 0.56));
    padding: 16px 18px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
  }

  .comment-meta {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    align-items: center;
    gap: 10px 12px;
    margin-bottom: 10px;
  }

  .comment-author {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 4px 10px;
    min-width: 0;
  }

  .comment-author strong {
    color: var(--text);
    line-height: 1.25;
  }

  .comment-author time {
    color: var(--muted);
    font-size: 13px;
  }

  .comment-avatar,
  .comment-avatar-fallback {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 999px;
  }

  .comment-avatar-fallback {
    background: linear-gradient(135deg, rgba(71, 233, 255, 0.18), rgba(255, 95, 200, 0.16));
    color: var(--accent-strong);
    font-size: 14px;
    font-weight: 900;
  }

  .comment-avatar {
    object-fit: cover;
  }

  .comment-body {
    margin: 0;
    color: var(--text);
    line-height: 1.75;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .comments-empty {
    margin: 18px 0 0;
    color: var(--muted);
  }

  [data-comment-status]:empty {
    display: none;
  }

  [data-theme="light"] .comment-form,
  [data-theme="light"] .comment-card {
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 30px rgba(31, 78, 93, 0.08);
  }

  [data-theme="light"] .comment-form textarea {
    background: rgba(255, 255, 255, 0.74);
  }

  @media (max-width: 620px) {
    .comments-heading,
    .comment-form-actions {
      align-items: flex-start;
      flex-direction: column;
    }

    .comments-heading .auth-button,
    .comment-form-actions .button {
      width: 100%;
    }
  }
</style>

<script>
  // @ts-nocheck
  import { getSupabaseClient, getUserLabel } from "../lib/supabase-browser";

  const root = document.querySelector("[data-comments]");
  const supabase = await getSupabaseClient();
  const postSlug = root?.dataset.postSlug;
  const list = root?.querySelector("[data-comment-list]");
  const empty = root?.querySelector("[data-comments-empty]");
  const loading = root?.querySelector("[data-comments-loading]");
  const unavailable = root?.querySelector("[data-comments-unavailable]");
  const countNode = root?.querySelector("[data-comment-count]");
  const loginButton = root?.querySelector("[data-comments-login]");
  const form = root?.querySelector("[data-comment-form]");
  const textarea = form?.querySelector("textarea");
  const status = root?.querySelector("[data-comment-status]");
  const submitButton = root?.querySelector("[data-comment-submit]");

  const getSafeAvatar = (value) => {
    if (!value) return "";
    try {
      const url = new URL(value);
      if (!["http:", "https:"].includes(url.protocol)) return "";
      return url.href;
    } catch {
      return "";
    }
  };

  const getInitial = (value) => {
    const trimmed = String(value || "匿名").trim();
    return trimmed.slice(0, 1).toUpperCase() || "匿";
  };

  const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });

  const formatDate = (value) => {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";
    return dateFormatter.format(date);
  };

  const setStatus = (message = "") => {
    if (status) status.textContent = message;
  };

  const setUnavailable = (message) => {
    if (loading) loading.hidden = true;
    if (empty) empty.hidden = true;
    if (list) list.replaceChildren();
    if (unavailable) {
      unavailable.textContent = message;
      unavailable.hidden = false;
    }
    if (countNode) countNode.textContent = "0";
  };

  const renderComment = (comment) => {
    const article = document.createElement("article");
    article.className = "comment-card";

    const meta = document.createElement("div");
    meta.className = "comment-meta";

    const avatar = getSafeAvatar(comment.author_avatar);
    if (avatar) {
      const image = document.createElement("img");
      image.className = "comment-avatar";
      image.src = avatar;
      image.alt = "";
      meta.append(image);
    } else {
      const fallback = document.createElement("span");
      fallback.className = "comment-avatar-fallback";
      fallback.setAttribute("aria-hidden", "true");
      fallback.textContent = getInitial(comment.author_name);
      meta.append(fallback);
    }

    const author = document.createElement("div");
    author.className = "comment-author";

    const authorName = document.createElement("strong");
    authorName.textContent = comment.author_name || "匿名用户";
    author.append(authorName);

    const createdAt = formatDate(comment.created_at);
    if (createdAt) {
      const time = document.createElement("time");
      time.dateTime = comment.created_at;
      time.textContent = createdAt;
      author.append(time);
    }

    meta.append(author);

    const body = document.createElement("p");
    body.className = "comment-body";
    body.textContent = comment.content || "";

    article.append(meta, body);
    return article;
  };

  const renderAuth = async () => {
    if (!supabase) return;
    const { data } = await supabase.auth.getUser();
    const user = data.user;
    if (loginButton) loginButton.hidden = Boolean(user);
    if (form) form.hidden = !user;
    setStatus("");
  };

  const loadComments = async () => {
    if (!root || !postSlug || !list) return;
    if (loading) loading.hidden = false;
    if (empty) empty.hidden = true;
    if (unavailable) unavailable.hidden = true;
    list.replaceChildren();

    if (!supabase) {
      setUnavailable("评论系统尚未配置。阅读不受影响，配置 Supabase 后即可发表评论。");
      if (loginButton) loginButton.hidden = true;
      return;
    }

    const { data, error } = await supabase
      .from("comments")
      .select("id, author_name, author_avatar, content, created_at")
      .eq("post_slug", postSlug)
      .eq("status", "visible")
      .order("created_at", { ascending: true });

    if (loading) loading.hidden = true;

    if (error) {
      setUnavailable("评论读取失败，请稍后刷新重试。");
      return;
    }

    const comments = data ?? [];
    if (countNode) countNode.textContent = String(comments.length);
    list.replaceChildren(...comments.map(renderComment));

    if (empty) empty.hidden = Boolean(comments.length);
  };

  const getCommentAuthor = async (user) => {
    const { data } = await supabase
      .from("profiles")
      .select("display_name, avatar_url")
      .eq("id", user.id)
      .maybeSingle();

    return {
      name: data?.display_name || getUserLabel(user),
      avatar: data?.avatar_url || user.user_metadata?.avatar_url || null,
    };
  };

  loginButton?.addEventListener("click", async () => {
    await supabase?.auth.signInWithOAuth({
      provider: "github",
      options: { redirectTo: window.location.href },
    });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!supabase || !textarea || !submitButton) return;
    setStatus("发布中...");
    submitButton.disabled = true;
    form.setAttribute("aria-busy", "true");

    try {
      const { data } = await supabase.auth.getUser();
      const user = data.user;
      if (!user) {
        setStatus("请先登录。");
        return;
      }

      const content = textarea.value.trim();
      if (!content) {
        setStatus("评论不能为空。");
        textarea.focus();
        return;
      }

      const author = await getCommentAuthor(user);
      const { error } = await supabase.from("comments").insert({
        post_slug: postSlug,
        user_id: user.id,
        author_name: author.name,
        author_avatar: author.avatar,
        content,
        status: "visible",
      });

      if (error) {
        setStatus("发布失败，请稍后重试。");
        return;
      }

      textarea.value = "";
      setStatus("已发布。");
      await loadComments();
    } finally {
      submitButton.disabled = false;
      form.removeAttribute("aria-busy");
    }
  });

  window.addEventListener("blog-auth-change", renderAuth);
  await renderAuth();
  await loadComments();
</script>
